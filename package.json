{
  "name": "loose",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:server": "pnpm --filter @loose/server dev",
    "dev:web": "pnpm --filter @loose/web dev",
    "typecheck": "turbo run typecheck",
    "test:e2e": "node tests/e2e/run.mjs",
    "test:ui": "playwright test",
    "db:generate": "pnpm --filter @loose/db generate",
    "db:migrate": "pnpm --filter @loose/db migrate"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "ws": "^8.18.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
