# ── Loose configuration ─────────────────────────────────────────────────────
# Every external surface is a swappable provider with a safe default, so the app
# runs with NONE of these set. Pick a driver (or set the credentials and it's
# auto-detected). Swap a vendor = implement the port interface + add a *_DRIVER case.

PORT=8787
APP_URL=http://localhost:5173

# ── Store (Store port) ── default: in-memory ────────────────────────────────
# Set DATABASE_URL to persist: postgres://… (Neon/PG) or pglite://<dir> (embedded).
# DATABASE_URL=pglite://./.loosedb
# DATABASE_URL=postgres://loose:loose@localhost:5432/loose

# ── PubSub port ── default: in-memory (single instance) ─────────────────────
# Set REDIS_URL for multi-instance fan-out.
# REDIS_URL=redis://localhost:6379

# ── Storage port ── STORAGE_DRIVER: local (default) | memory | s3 ───────────
# FILES_DIR=./.loose-files                 # local driver
# STORAGE_DRIVER=s3                         # S3 / Cloudflare R2 / MinIO
# S3_BUCKET=…
# S3_ACCESS_KEY_ID=…
# S3_SECRET_ACCESS_KEY=…
# S3_REGION=auto
# S3_ENDPOINT=https://<acct>.r2.cloudflarestorage.com   # set for R2/MinIO; omit for AWS
# S3_PUBLIC_BASE_URL=https://files.example.com

# ── LLM port (agent runs) ── LLM_DRIVER: anthropic (if key) | echo (default) ─
# ANTHROPIC_API_KEY=…
# LOOSE_AGENT_MODEL=claude-opus-4-8

# ── Media port (huddles) ── MEDIA_DRIVER: livekit (if creds) | none (default) ─
# LIVEKIT_URL=wss://<you>.livekit.cloud
# LIVEKIT_API_KEY=…
# LIVEKIT_API_SECRET=…

# ── Billing port ── BILLING_DRIVER: stripe (if keys) | none (default) ────────
# STRIPE_SECRET_KEY=…
# STRIPE_PRICE_ID=…
# STRIPE_WEBHOOK_SECRET=…

# ── Analytics port ── ANALYTICS_DRIVER: posthog (if key) | noop (default) ────
# POSTHOG_KEY=…            # server (posthog-node)
# POSTHOG_HOST=https://us.i.posthog.com
# VITE_POSTHOG_KEY=…       # web client (posthog-js)

# ── Auth port ── AUTH_DRIVER: local (default) ───────────────────────────────
# (OIDC/SAML adapters implement AuthProvider and slot into createAuth().)

# ── Tenancy / SCIM ──────────────────────────────────────────────────────────
WORKSPACE_SEAT_LIMIT=50
# SCIM_TOKEN=…             # enable SCIM 2.0 provisioning
# SCIM_WORKSPACE_ID=w_main

# ── Slack bridge ── inbound needs no token; outbound mirror needs a bot token ─
# SLACK_BOT_TOKEN=…

# ── Web client ──────────────────────────────────────────────────────────────
VITE_HTTP_URL=http://localhost:8787
VITE_WS_URL=ws://localhost:8787/ws
